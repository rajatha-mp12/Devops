pipeline {
    agent any

    tools {
        maven 'Maven-3.9'
        jdk   'JDK-17'
    }

    environment {
        APP_NAME    = 'devops-maven-app'
        BUILD_ENV   = 'CI'
    }

    stages {
        stage('Checkout') {
            steps {
                git branch: 'main',
                    url: 'https://gitlab.com/devops-bcsl657d/course-practicals.git'
            }
        }
        stage('Compile') {
            steps {
                sh 'mvn compile'
            }
        }
        stage('Test') {
            steps {
                sh 'mvn test'
            }
            post {
                always {
                    junit '**/target/surefire-reports/*.xml'
                }
            }
        }
        stage('Package') {
            steps {
                sh 'mvn package -DskipTests'
                archiveArtifacts artifacts: 'target/*.jar', fingerprint: true
            }
        }
        stage('Code Quality') {
            steps {
                echo 'Running code quality checks...'
                sh 'mvn checkstyle:check || true'
            }
        }
    }
    post {
        success { echo 'Build SUCCEEDED!' }
        failure { echo 'Build FAILED — check logs!' }
        always  { cleanWs() }
    }
}
