pipeline {
    agent any

    environment {
        ARTIFACT = 'target/devops-maven-app-1.0-SNAPSHOT.jar'
        ANSIBLE_HOST_KEY_CHECKING = 'False'
    }

    stages {
        stage('Checkout') {
            steps {
                git branch: 'main',
                    url: 'https://gitlab.com/devops-bcsl657d/course-practicals.git'
            }
        }
        stage('Build') {
            steps { sh 'mvn clean package -DskipTests' }
        }
        stage('Test') {
            steps { sh 'mvn test' }
            post { always { junit '**/target/surefire-reports/*.xml' } }
        }
        stage('Archive Artifact') {
            steps {
                archiveArtifacts artifacts: 'target/*.jar', fingerprint: true
            }
        }
        stage('Deploy with Ansible') {
            steps {
                sh '''
                    ansible-playbook \
                      -i ansible/hosts.ini \
                      ansible/setup_webserver.yml \
                      -v
                '''
            }
        }
    }
    post {
        success { echo 'Deployed successfully via Ansible!' }
        failure { echo 'Pipeline failed — check stages above.' }
    }
}
